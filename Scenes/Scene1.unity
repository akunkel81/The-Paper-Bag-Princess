--- !u!114 &1304387780
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1304387778}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 48dada2014dd85542bc7ae08489672a6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  dialogueBox: {fileID: 1862308809}
  conversation:
  - text: '"Hark who goes there?"'
    portrait: {fileID: 21300000, guid: 9ecb9a4fc917bbe4e99616cb15a73591, type: 3}
  - text: '"It''s me, Princess Elizabeth!"'
    portrait: {fileID: 21300000, guid: dfa01e01400b9c54f89ebdcecfef7ead, type: 3}
  - text: '"Ha," the Knight scoffs, "you really expect me to believe you''re the
      princess? Dressed like that?"'
    portrait: {fileID: 21300000, guid: 9ecb9a4fc917bbe4e99616cb15a73591, type: 3}
  - text: '"My castle burned down from the dragon! Please you must let me through!"'
    portrait: {fileID: 21300000, guid: dfa01e01400b9c54f89ebdcecfef7ead, type: 3}
  - text: '"I''ve heard enough. Ladies should be dressed appropriately if they wish
      to enter through here."'
    portrait: {fileID: 21300000, guid: 9ecb9a4fc917bbe4e99616cb15a73591, type: 3}
  - text: '"Unless you decide to change your attire, I''m not letting a filthy beggar-child
      in!."'
    portrait: {fileID: 21300000, guid: 9ecb9a4fc917bbe4e99616cb15a73591, type: 3}
  - text: '"If you cross this way again, I will have to remove you by force!"'
    portrait: {fileID: 21300000, guid: 9ecb9a4fc917bbe4e99616cb15a73591, type: 3}
  - text: '"Ugh! This is unbelievable!"'
    portrait: {fileID: 21300000, guid: dfa01e01400b9c54f89ebdcecfef7ead, type: 3}
