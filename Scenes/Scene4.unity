  m_Script: {fileID: 11500000, guid: 92746c38caf8a8c4399aefb83b677003, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::FinalConvoTrigger
  dialogueBox: {fileID: 1862308809}
  conversation:
  - text: In it's defeat the Dragon flies off...leaving you and Ronald alone.
    portrait: {fileID: 0}
  - text: '"Ronald! You''re safe, thank goodness. I''m here to rescue you!"'
    portrait: {fileID: 21300000, guid: dfa01e01400b9c54f89ebdcecfef7ead, type: 3}
  - text: '"Elizabeth?"'
    portrait: {fileID: 8416243949045666254, guid: 6ed75f110a73e144e97d86a4afb848d9, type: 3}
  - text: '"Y-yes?"'
    portrait: {fileID: 21300000, guid: dfa01e01400b9c54f89ebdcecfef7ead, type: 3}
  - text: '"You look absolutely filthy! Why are you wearing garbage? You''re not
      dressed like a proper Princess at all!"'
    portrait: {fileID: 8416243949045666254, guid: 6ed75f110a73e144e97d86a4afb848d9, type: 3}
  - text: '"What?"'
    portrait: {fileID: 21300000, guid: dfa01e01400b9c54f89ebdcecfef7ead, type: 3}
  isFinalChoice: 1
  continueEndingScene: Rescue
  dumpEndingScene: Dump
